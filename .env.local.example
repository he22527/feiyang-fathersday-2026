# 複製成 .env.local（本機測試用），或用 `vercel env add` 逐一加到 Vercel。
# 這些值不要進 git！

# ── Firebase Firestore（後端資料庫，專案 myproject-bf2d2）──
# 到 Firebase 主控台 → 專案設定 → 服務帳戶 → 產生新的私密金鑰，下載 JSON，
# 整包內容（單行）貼到這個變數：
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"myproject-bf2d2", ... }

# （選填）集合名稱，預設 registrations
# FIRESTORE_COLLECTION=registrations

# ── Gmail SMTP（報名通知信）──
GMAIL_USER=taiwan.kwei@gmail.com
GMAIL_APP_PASSWORD=你的_Google應用程式密碼_16碼

# ── 收件人（選填；不填則用程式內建的 4 位同工）──
# NOTIFY_TO=hsuehmei@ceci.com.tw,coshin@ceci.com.tw,taiwan.kwei@ceci.com.tw,g0306@ceci.com.tw

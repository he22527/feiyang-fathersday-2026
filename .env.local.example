# 複製成 .env.local（本機測試用），或用 `vercel env add` 逐一加到 Vercel。
# 這些值不要進 git！

# ── Filebase（S3 相容物件儲存，當後端資料庫）──
FILEBASE_KEY=你的_Filebase_Access_Key
FILEBASE_SECRET=你的_Filebase_Secret_Key
FILEBASE_BUCKET=myproject

# ── Gmail SMTP（報名通知信）──
GMAIL_USER=taiwan.kwei@gmail.com
GMAIL_APP_PASSWORD=你的_Google應用程式密碼_16碼

